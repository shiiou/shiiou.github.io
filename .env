# Port du serveur (Railway/Render le définissent automatiquement, sinon 3000 par défaut)
PORT=8080

# Jour et heure d'envoi automatique du récap hebdomadaire (format cron)
# Exemple par défaut : tous les dimanches à 20h00
WEEKLY_CRON=0 20 * * 0

# Heure de vérification quotidienne pour le récap mensuel
# (envoyé automatiquement le dernier jour du mois à cette heure)
MONTHLY_CHECK_CRON=55 23 * * *

# Versement automatique du revenu hebdomadaire
INCOME_AMOUNT=110
# Tous les mardis à 9h00 (format cron : minute heure jour mois jour-semaine ; 2 = mardi)
INCOME_CRON=0 9 * * 2
